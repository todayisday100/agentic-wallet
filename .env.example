# ═══════════════════════════════════════════
# Enclave Agent Configuration
# ═══════════════════════════════════════════

# Agent identity
ENC_AGENT_ID=enc-primary-001
ENC_NETWORK=testnet

# Treasury limits
ENC_TOTAL_BUDGET=10000
ENC_ALERT_THRESHOLD=0.2
ENC_MAX_SINGLE_TX=500

# x402 Protocol
ENC_X402_ENDPOINT=https://x402.testnet.enclave.dev/v1
ENC_X402_TIMEOUT_MS=3000

# KYA (Know Your Agent) scoring
ENC_KYA_MIN_SCORE=0.6
ENC_KYA_CHECK_INTERVAL_S=30

# Simulation speed (ms between events in the loop)
ENC_TICK_INTERVAL_MS=2000

# Logging
ENC_LOG_LEVEL=info
